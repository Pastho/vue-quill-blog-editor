{
  "name": "@pastho/vue-quill-blog-editor",
  "version": "1.1.0",
  "main": "dist/vue-quill-blog-editor.cjs.js",
  "module": "dist/vue-quill-blog-editor.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-quill-blog-editor.es.js",
      "require": "./dist/vue-quill-blog-editor.cjs.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css",
    "./dist/vue-quill-blog-editor.es.js",
    "./dist/vue-quill-blog-editor.cjs.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pastho/vue-quill-blog-editor.git"
  },

  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && node scripts/postbuild.js && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "dev": "vite",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "quill": "^2.0.3",
    "vue": "^3.3.0"
  },
  "keywords": [
    "vue",
    "editor",
    "quill",
    "component",
    "vue3"
  ],
  "author": "Thomas Pasberg",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "quill": "^2.0.3",
    "typescript": "^5.0.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.3",
    "vue": "^3.3.0",
    "vue-tsc": "^2.2.10"
  }
}
